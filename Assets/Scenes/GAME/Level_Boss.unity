  m_StaticEditorFlags: 0
  m_IsActive: 1
--- !u!114 &510205886
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 510205885}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 28981e3a8f4844c499a31eea9bdb0590, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  DialogueSystemRef: {fileID: 654902004}
  GoodEndingLines:
  - SpeakerName: 
    CharacterSprite: {fileID: 0}
    Text: "\"\xBFR-Raven\u2026? \xBFDe verdad eres t\xFA?\""
  - SpeakerName: Raven
    CharacterSprite: {fileID: 0}
    Text: "\"\xBFTe parece que tengo cara de alguien m\xE1s?\""
  - SpeakerName: Cori
    CharacterSprite: {fileID: 0}
    Text: " \"No\u2026 Pero vi\xE9ndote es como si no te conociera en absoluto.\""
  - SpeakerName: Raven
    CharacterSprite: {fileID: 0}
    Text: "\"\xBFTe has acobardado? Acaba conmigo si eres tan valiente. \xA1Ven aqu\xED!\""
  - SpeakerName: Cori
    CharacterSprite: {fileID: 0}
    Text: "\"\xA1Basta! Entr\xE9 a este mugriento edificio con el \xFAnico objetivo\r\nde
      traerte de vuelta, y me niego a salir de \xE9l sin cumplirlo.\""
  - SpeakerName: Raven
    CharacterSprite: {fileID: 0}
    Text: "\"Veo que tu terquedad tan solo ha aumentado desde que saliste\r\nde la
      polic\xEDa\u2026\""
  - SpeakerName: 
    CharacterSprite: {fileID: 0}
    Text: "\"Sin l\xEDder, la organizaci\xF3n de Raven fue desmantelada a lo largo\r\nde
      esa madrugada. Los rehenes fueron liberados.\r\nRaven y Cori ahora trabajan
      juntas, y planean hacerlo durante\r\nmucho m\xE1s tiempo.\""
  BadEndingLines:
  - SpeakerName: 
    CharacterSprite: {fileID: 0}
    Text: " \"El resto de la noche transcurri\xF3 de forma silenciosa.\r\nAnte el
      cuerpo inerte de Cori, Raven no pudo m\xE1s que observar.\""
  - SpeakerName: 
    CharacterSprite: {fileID: 0}
    Text: "\"Tir\xF3 sus armas y cay\xF3 de rodillas.\r\nRaven era consciente de
      que su hermana podr\xEDa llegar hasta ella,\r\ny pens\xF3 que estaba dispuesta
      a acabar con ella si se cruzaba en su camino.\""
  - SpeakerName: 
    CharacterSprite: {fileID: 0}
    Text: "\"Y ahora que se hab\xEDa hecho realidad, el mundo perdi\xF3 su color\r\nantes
      de que ella pudiera darse cuenta.\r\nNadie supo nada m\xE1s de la organizaci\xF3n
      de Raven.\""
  BossGameObject: {fileID: 940375069}
