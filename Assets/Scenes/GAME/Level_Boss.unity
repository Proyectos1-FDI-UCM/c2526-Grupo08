  m_EditorClassIdentifier: 
  DialogueSystemRef: {fileID: 654902004}
  AutoStartOnLoad: 1
  AutoStartDelay: 0.2
  Lines:
  - SpeakerName: 
    CharacterSprite: {fileID: 0}
    Text: " \"Al otro lado de esa puerta estaba la persona que hab\xEDa dado\r\n\xF3rdenes
      a todos los que Cori hab\xEDa derrotado esta noche.\""
  - SpeakerName: 
    CharacterSprite: {fileID: 0}
    Text: "\"La persona por la que hab\xEDa entrado a este mugriento edificio.\""
  - SpeakerName: Cori
    CharacterSprite: {fileID: 0}
    Text: " \"Raven\u2026 \xBFqu\xE9 te ha pasado?\""
  RequireItem: 0
  RequiredAmount: 0
  FeedbackText: "Necesitas m\xE1s objetos para continuar."
  FeedbackSprite: {fileID: 0}
