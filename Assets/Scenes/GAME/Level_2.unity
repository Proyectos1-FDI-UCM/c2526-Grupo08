  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 77c02a8530f3c204a86879a5bdb092fd, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  DialogueSystemRef: {fileID: 31857259}
  Lines:
  - SpeakerName: 
    CharacterSprite: {fileID: 0}
    Text: " \"Tercera planta. El ascensor se detuvo con un golpe seco.\r\nDesde aqu\xED
      Cori pod\xEDa o\xEDr algo\u2026 \xBFrespiraci\xF3n? \xBFPasos?\""
  - SpeakerName: 
    CharacterSprite: {fileID: 0}
    Text: "\"Los rehenes estaban cerca. Y tambi\xE9n lo estaba quien los reten\xEDa.\""
  - SpeakerName: Cori
    CharacterSprite: {fileID: 0}
    Text: '"Ya casi. Aguanta."'
  RequireItem: 2
  RequiredAmount: 2
  FeedbackText: "Necesitas m\xE1s objetos para continuar."
  FeedbackSprite: {fileID: 0}
  PauseWhileActive: 1
  TriggerLevelTransitionOnEnd: 0
  NextSceneName: Level_Boss
