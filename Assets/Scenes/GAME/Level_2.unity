--- !u!114 &1624189370
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1624189368}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 09a8ed9b314dd2f42b4969dea1df8538, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  InteractionRadius: 1.2
  PromptUI: {fileID: 1259386709}
  DocumentCanvas: {fileID: 540953846}
  PageText: {fileID: 2088525388}
  PageIndicator: {fileID: 318956719}
  ContinueHint: {fileID: 135256263}
  HintText: "F  /  B (mando)  \u2192  siguiente p\xE1gina"
  HintTextLastPage: "F  /  B (mando)  \u2192  cerrar"
  Pages:
  - "\"Cori abre un caj\xF3n cerrado con una peque\xF1a llave. Dentro hay una carpeta
    con fotos de muestras y lugares que no reconoce.\""
  - " \"Los documentos contienen informaci\xF3n sobre experimentos con el nuevo cristal
    m\xE1gico. Numerosas organizaciones secretas, incluida la suya, compraban grandes
    cantidades del mineral.\""
  - " \"Al final de los informes, una nota escrita a mano: 'Si continuamos as\xED,
    dominaremos a las dem\xE1s organizaciones en las pr\xF3ximas dos semanas. Jam\xE1s
    pens\xE9 que escribir\xEDa esto, pero por primera vez estoy orgullosa de mis
    subordinados.'\""
  - "\"'En la reserva a veces contemplo aspectos m\xE1s banales de la piedra. Por
    ejemplo, su color es igual que su color favorito.' \u2014 Cori guard\xF3 la carpeta
    en su capa.\""
  PlayerMovementRef: {fileID: 1917631977}
