MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 7457065070476480303}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 77c02a8530f3c204a86879a5bdb092fd, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  DialogueSystemRef: {fileID: 0}
  AutoStartOnLoad: 0
  AutoStartDelay: 0.1
  Lines:
  - SpeakerName: 
    CharacterSprite: {fileID: 0}
    Text: "\"El ascensor cruji\xF3 al ponerse en marcha.\r\nCori cont\xF3 los segundos
      en silencio mientras las paredes\r\nde metal oxidado ascend\xEDan a su alrededor.\""
  - SpeakerName: 
    CharacterSprite: {fileID: 0}
    Text: "\"Segunda planta. El edificio empeoraba con cada piso:\r\ntechos desmoronados,
      cables a la vista, y m\xE1s guardias.\""
  - SpeakerName: Cori
    CharacterSprite: {fileID: 0}
    Text: "\"Aqu\xED arriba hay m\xE1s movimiento. Tienen algo que proteger.\""
  RequireItem: 1
  RequiredAmount: 3
  FeedbackText: '"Necesitas los 3 fusibles para activar el ascensor."'
  FeedbackSprite: {fileID: 0}
  PauseWhileActive: 1
  TriggerLevelTransitionOnEnd: 1
  NextSceneName: Level_2
